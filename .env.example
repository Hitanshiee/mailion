# App Base URL
APP_URL=http://localhost:3000

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Gemini API Key
GEMINI_API_KEY=

# Outscraper API Key (for LinkedIn & Company Enrichment)
# Get API key from https://outscraper.com/
# Enables: Google search-based LinkedIn data, company insights, email discovery
OUTSCRAPER_API_KEY=

# Firebase Admin Service Account (for backend Firestore access)
# Get these from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
